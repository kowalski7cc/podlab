#!/usr/bin/env bash
set -e
. "$PODLAB_BASE"/setenv
KEY_PATH="$(realpath $SSH_PATH)/$SSH_KEY_NAME"

export ANSIBLE_SSH_EXECUTABLE="${ANSIBLE_SSH_EXECUTABLE:-"$PODLAB_BASE"/bin/ssh}"
export ANSIBLE_INVENTORY="${ANSIBLE_INVENTORY:-"$PODLAB_BASE"/inventory}"
export ANSIBLE_PRIVATE_KEY_FILE="${ANSIBLE_PRIVATE_KEY_FILE:-"$KEY_PATH"}"
export ANSIBLE_REMOTE_USER="${ANSIBLE_REMOTE_USER:-ansible}"
export ANSIBLE_HOST_KEY_CHECKING="${ANSIBLE_HOST_KEY_CHECKING:-false}"
export ANSIBLE_PYTHON_INTERPRETER="${ANSIBLE_PYTHON_INTERPRETER:-auto_silent}"
export ANSIBLE_DEPRECATION_WARNINGS="${ANSIBLE_DEPRECATION_WARNINGS:-False}"

ansible $@